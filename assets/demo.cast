{"version":3,"term":{"cols":80,"rows":24},"timestamp":1782385197,"command":"bun scripts/demo.ts","env":{"SHELL":"/bin/zsh"}}
[0.149, "o", "\u001b[1magentbus\u001b[22m\u001b[2m — two agent sessions talking\u001b[22m\r\n"]
[0.702, "o", "\r\n"]
[0.708, "o", "\u001b[2m$ \u001b[22mAGENTBUS_NAME=frontend claude --dangerously-load-development-channels server:agentbus-channel\r\n"]
[0.705, "o", "\u001b[2m$ \u001b[22mAGENTBUS_NAME=backend  claude --dangerously-load-development-channels server:agentbus-channel\r\n"]
[1.527, "o", "\u001b[32m  ✓ both online — send (MCP) + claude-channel delivery\u001b[39m\r\n"]
[0.701, "o", "\r\n"]
[0.701, "o", "\u001b[36mfrontend ▸ \u001b[39mlist_peers\r\n"]
[0.716, "o", "\u001b[2m  online peers:\r\n    backend\r\n  * frontend (you)\u001b[22m\r\n"]
[0.702, "o", "\r\n"]
[0.703, "o", "\u001b[36mfrontend ▸ \u001b[39msend_message  to=backend  text=\u001b[33m\"what's the shape of GET /users?\"\u001b[39m\r\n"]
[1.506, "o", "\u001b[32m  ✓ delivered into backend's running session:\u001b[39m\r\n"]
[0.746, "o", "\u001b[2m  <channel source=\"agentbus\" from=\"frontend\" msg_id=\"1\">\r\n    what's the shape of GET /users?\r\n  </channel>\u001b[22m\r\n"]
[0.702, "o", "\r\n"]
[0.701, "o", "\u001b[36mbackend ▸ \u001b[39msend_message  to=frontend  text=\u001b[33m\"{ id, name, email }\"\u001b[39m\r\n"]
[1.521, "o", "\u001b[32m  ✓ reply delivered to frontend:\u001b[39m\r\n"]
[0.701, "o", "\u001b[2m  <channel source=\"agentbus\" from=\"backend\" msg_id=\"2\">\r\n    { id, name, email }\r\n  </channel>\u001b[22m\r\n"]
[0.702, "o", "\r\n"]
[0.703, "o", "\u001b[32m  ✓ send (always-on MCP) + pluggable delivery. \u001b[39m\u001b[2mgithub.com/biswajitpatra/agentbus\u001b[22m\r\n"]
[2.725, "x", "0"]
