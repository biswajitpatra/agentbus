# Name for this session — peers address you by this, and it's how the send
# server and your delivery agree on who you are. Set it to participate; if unset
# you can still send, but you won't be registered as an addressable peer.
AGENTBUS_NAME=

# Optional override for the shared bus directory.
# Default: ~/.agentbus
AGENTBUS_HOME=

# Optional Trigger (PULL) implementation: unset = file-watch (default), or "poll".
AGENTBUS_TRIGGER=
